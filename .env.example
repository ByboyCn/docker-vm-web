# ====================================================
#  Docker 虚拟机网站 - 环境配置
#  使用方法:cp .env.example .env 然后修改下面的值
# ====================================================

# 返回给用户的 IP。留空则自动探测宿主机 IP。
# 多网卡/云主机时建议手动写死公网 IP,例如:HOST_IP=1.2.3.4
HOST_IP=

# SSH 宿主端口范围。新开的容器会随机分配这个范围内的一个端口。
# 注意:云服务器需要在安全组/防火墙放行这个范围。
PORT_MIN=20000
PORT_MAX=30000

# ---------- 用户登录系统 ----------
# 初始管理员账号。仅首启(Users 表为空)时创建一次,之后改这里不会影响已存在的账号。
# ⚠️ 上线务必改成你自己的用户名和强密码!
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me-please

# (已废弃,保留向后兼容)旧版管理后台 token。新版改用登录账号的 IsAdmin 字段。
# ADMIN_TOKEN=change-me-to-random-string

# ---------- 每台容器的资源上限 ----------
VM_CPU_CORES=1              # CPU 核数(可小数,如 0.5)
VM_MEMORY_MB=1024           # 内存上限(MB)
VM_PIDS_LIMIT=200           # 进程/线程数上限(防 fork 炸弹)
VM_DISK_SIZE=5g             # 每容器 /home 挂载的 loop 文件大小(硬限制,系统级强制)
VM_DISK_ALERT=6g            # 后台扫描告警阈值(容器可写层总大小超过此值会在后台标红)
VM_DISK_SCAN_MINUTES=10     # 后台扫描间隔(分钟)
VM_VOLUME_DIR=/var/lib/docker-vm-volumes   # loop 文件存放目录(必须和 docker-compose 挂载一致)
DOCKER_OVERLAY_DIR=/var/lib/docker/overlay2  # docker overlay2 目录(后台扫描用,只读挂载)

# ---------- 名额限量 ----------
QUOTA_INITIAL_TOTAL=5       # 首启初始化的全局名额总数(之后由 admin 在后台管理)

# ---------- LXCFS(可选,让容器内 /proc 反映实际配额)----------
# 启用后,容器内 free/nproc/top 看到的是 1核/1G,而不是宿主全部资源
# 要求宿主已安装并运行 lxcfs。未装时后端自动降级(容器内看到宿主真实资源,不影响功能)
ENABLE_LXCFS=true
LXCFS_PROC_DIR=/var/lib/lxcfs/proc   # 宿主 lxcfs 的 proc 目录路径

# 容器内创建的 SSH 用户名。
SSH_USER=user

# ---------- 可选项(通常无需修改) ----------
# SSH 基础镜像名(后端启动时自动 build)
# SSH_IMAGE_NAME=docker-vm-alpine:latest

# 镜像构建目录(容器内路径)
# SSH_IMAGE_CONTEXT_DIR=/app/image

# CORS 允许的来源,逗号分隔,默认 *
# CORS_ORIGINS=*

# Docker daemon 地址(默认 unix socket)
# DOCKER_HOST=unix:///var/run/docker.sock
